{
  "name": "drizzle-migration-guard",
  "version": "1.0.0",
  "description": "A GitHub Action that explains Drizzle migration collisions in pull requests.",
  "private": false,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "package": "npm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "c8 --reporter=text --reporter=lcov --exclude 'scripts/**' --exclude '.tmp-*/**' --exclude 'tests/**' --exclude 'dist/**' --check-coverage --lines 84 --functions 97 --branches 78 --statements 84 npm test",
    "verify:dist": "node scripts/verify-dist.mjs",
    "ci": "npm run build && npm test",
    "ci:strict": "npm run typecheck && npm run ci && npm run test:coverage && npm run verify:dist"
  },
  "keywords": [
    "drizzle",
    "drizzle-kit",
    "github-action",
    "migrations",
    "pull-request"
  ],
  "author": "saudademjj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saudademjj/drizzle-migration-guard.git"
  },
  "homepage": "https://github.com/saudademjj/drizzle-migration-guard#readme",
  "bugs": {
    "url": "https://github.com/saudademjj/drizzle-migration-guard/issues"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.1",
    "fast-glob": "^3.3.2",
    "jiti": "^1.21.0",
    "minimatch": "^10.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "c8": "^11.0.0",
    "drizzle-kit": "0.31.8",
    "drizzle-orm": "0.44.7",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
